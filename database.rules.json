{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      "$code": {
        ".read": "auth != null",
        "meta": {
          ".write": "auth != null && (!data.exists() || data.child('hostUid').val() === auth.uid)"
        },
        "slots": {
          "p0": {
            ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid)"
          },
          "p1": {
            ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid) && root.child('rooms').child($code).child('meta/status').val() === 'waiting'"
          },
          "p2": {
            ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid) && root.child('rooms').child($code).child('meta/status').val() === 'waiting'"
          },
          "p3": {
            ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid) && root.child('rooms').child($code).child('meta/status').val() === 'waiting'"
          }
        },
        "state": {
          ".write": "auth != null && root.child('rooms').child($code).child('meta/hostUid').val() === auth.uid"
        },
        "actions": {
          "$pushKey": {
            ".write": "auth != null && newData.child('by').val() === auth.uid && (root.child('rooms').child($code).child('slots/p0/uid').val() === auth.uid || root.child('rooms').child($code).child('slots/p1/uid').val() === auth.uid || root.child('rooms').child($code).child('slots/p2/uid').val() === auth.uid || root.child('rooms').child($code).child('slots/p3/uid').val() === auth.uid)"
          }
        },
        "presence": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        }
      }
    }
  }
}
